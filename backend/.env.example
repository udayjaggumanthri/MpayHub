# Django Settings
DJANGO_ENV=development
SECRET_KEY=change-this-to-a-secure-random-value
DEBUG=True

# Database Configuration (preferred)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mpayhub

# Alternative DB settings (use only if DATABASE_URL is not set)
# DB_NAME=mpayhub
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432
USE_SQLITE=False

# Encryption Key (32-char minimum recommended)
ENCRYPTION_KEY=change-this-32-char-encryption-key

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email (production)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-app-password

# External Integrations
BBPS_API_KEY=your-bbps-api-key
BBPS_API_URL=https://api.bbps.example.com

# Payment Gateway
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# SMS Service
SMS_API_KEY=your-sms-api-key
SMS_API_URL=https://api.sms.example.com
SMS_PROVIDER=console

# Bank Validation
BANK_VALIDATION_API_KEY=your-bank-validation-api-key
BANK_VALIDATION_API_URL=https://api.bank-validation.example.com

# Production-only examples
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# SECURE_SSL_REDIRECT=True
