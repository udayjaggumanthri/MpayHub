{
  "info": {
    "_postman_id": "billavenue-bbps-uat-fixed",
    "name": "BillAvenue BBPS UAT (Prajnadhara)",
    "description": "Import and run collection for direct BillAvenue UAT API checks. Generates requestId and encRequest automatically in pre-request scripts.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function randomAlnum(len){",
          "  const chars='ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';",
          "  let out='';",
          "  for(let i=0;i<len;i++){ out += chars.charAt(Math.floor(Math.random()*chars.length)); }",
          "  return out;",
          "}",
          "function generateRequestId(){",
          "  const now = new Date();",
          "  const y = String(now.getFullYear()).slice(-1);",
          "  const start = new Date(now.getFullYear(), 0, 0);",
          "  const diff = now - start;",
          "  const oneDay = 1000*60*60*24;",
          "  const ddd = String(Math.floor(diff/oneDay)).padStart(3,'0');",
          "  const hh = String(now.getHours()).padStart(2,'0');",
          "  const mm = String(now.getMinutes()).padStart(2,'0');",
          "  return randomAlnum(27) + y + ddd + hh + mm;",
          "}",
          "function decodeMaybeHex(v){",
          "  const s = String(v || '').trim();",
          "  if(!s) return CryptoJS.enc.Utf8.parse('');",
          "  if(/^[0-9a-fA-F]+$/.test(s) && s.length % 2 === 0){",
          "    return CryptoJS.enc.Hex.parse(s);",
          "  }",
          "  return CryptoJS.enc.Utf8.parse(s);",
          "}",
          "function normalizeWordArray(wa, targetBytes){",
          "  let hex = CryptoJS.enc.Hex.stringify(wa || CryptoJS.lib.WordArray.create());",
          "  if(hex.length > targetBytes * 2) hex = hex.slice(0, targetBytes * 2);",
          "  while(hex.length < targetBytes * 2) hex += '30';",
          "  return CryptoJS.enc.Hex.parse(hex);",
          "}",
          "",
          "const reqId = generateRequestId();",
          "pm.collectionVariables.set('ba_request_id', reqId);",
          "",
          "const plainPayload = pm.collectionVariables.get('ba_plain_payload') || '{}';",
          "const keyInput = pm.collectionVariables.get('ba_working_key') || '';",
          "const ivInput = pm.collectionVariables.get('ba_iv') || '';",
          "",
          "const key = normalizeWordArray(decodeMaybeHex(keyInput), 16);",
          "const iv = normalizeWordArray(decodeMaybeHex(ivInput), 16);",
          "const encrypted = CryptoJS.AES.encrypt(",
          "  CryptoJS.enc.Utf8.parse(plainPayload),",
          "  key,",
          "  { iv: iv, mode: CryptoJS.mode.CBC, padding: CryptoJS.pad.Pkcs7 }",
          ").ciphertext.toString(CryptoJS.enc.Base64);",
          "",
          "pm.collectionVariables.set('ba_enc_request', encrypted);"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.collectionVariables.set('ba_last_status', String(pm.response.code || ''));",
          "pm.collectionVariables.set('ba_last_response_text', pm.response.text());",
          "pm.test('HTTP response received', function(){ pm.expect(pm.response.code).to.be.oneOf([200, 400, 401, 403, 404, 500]); });"
        ]
      }
    }
  ],
